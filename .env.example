# =============================================================
#  llm-caption 設定ファイル（.env.example）
#  このファイルを .env にコピーして各値を環境に合わせて編集する。
#  ハードコーディングは行わず、パスや API はすべてここで指定する。
# =============================================================

# ---- 入出力 -------------------------------------------------
# キャプションを付与する画像フォルダ（再帰的に探索される）。
# 生成した .txt は各画像と同じ場所・同名で書き出される（例: foo.jpg -> foo.txt）。
# CLI の --input を指定した場合はそちらが優先される。
IMAGE_DIR=./sample

# WD-EVA02 モデル一式（*.safetensors / config.json / selected_tags.csv）の置き場所。
# 3 点をこのフォルダ直下に配置する。入手先は README.md を参照。
MODEL_DIR=./model

# 除外タグリスト（*.csv）を置くフォルダ。直下の全 CSV を読み込み、
# 各行の先頭カラムのタグを Danbooru タグ出力から除外する（1 行目はヘッダ）。
# CSV が 1 つも無ければ除外は行わない。CLI の --no-ignore-tags で一時的に無効化できる。
# 入手先は README.md を参照。
IGNORE_TAGS_DIR=./ignore_tags

# ---- WD-EVA02 タガー ---------------------------------------
# 一般タグ採用のしきい値（0.0-1.0）。低いほど多くのタグを採用し、高いほど厳選される。
GENERAL_THRESHOLD=0.35
# キャラクタータグ採用のしきい値（0.0-1.0）。キャラ名は誤検出を避けるため一般タグより高めが目安。
CHARACTER_THRESHOLD=0.85
# レーティング（general/sensitive/questionable/explicit）をタグ先頭に含めるか（true/false）。
INCLUDE_RATINGS=false
# タグ内のアンダースコアを半角スペースに置換するか（例: long_hair -> long hair）（true/false）。
REPLACE_UNDERSCORE=true
# 括弧を \( \) にエスケープするか（SD 系学習で括弧が強調記号と誤解されるのを防ぐ）（true/false）。
ESCAPE_PARENTHESES=true

# ---- LLM（OpenAI 互換 API）---------------------------------
# LLM サーバーの base URL。ローカル llama-server の例: http://localhost:8080/v1
# 外部サーバー（OpenAI 互換 API）を使う場合はその base URL に変更する。
LLM_BASE_URL=http://localhost:8080/v1
# API キー。ローカル llama-server では任意の文字列でよい。外部 API では正規のキーを設定する。
LLM_API_KEY=local
# モデル名。llama-server では任意でよいが、外部 API では正式なモデル名を指定する。
LLM_MODEL=gemma
# 生成のランダム性（0.0-2.0 程度）。低いほど安定・再現的、高いほど多様な表現になる。
LLM_TEMPERATURE=0.4
# 1 回の生成で許可する最大トークン数。長いキャプションや思考ありモデルでは大きめにする。
LLM_MAX_TOKENS=1024
# 画像を LLM に渡すか（マルチモーダル）。
#   true  = 画像 + タグを渡す（llama-server 側に --mmproj が必要）
#   false = タグのみ渡す（mmproj 不要）
LLM_SEND_IMAGE=true
# 思考（reasoning）付きモデルの思考を無効化する。
#   true  = 思考オフ。回答のみを高速に得る（reasoning モデルでは必須級）
#   false = 思考あり。その場合 LLM_MAX_TOKENS を大きめ（1024+）にすること
LLM_DISABLE_THINKING=true
# 生成するキャプションの言語（例: English / Japanese）。LLM への指示に反映される。
CAPTION_LANGUAGE=English
# LLM に与えるシステムプロンプト。空にするとコード側の既定プロンプト（下と同一文）に
# フォールバックする。文中の {language} は CAPTION_LANGUAGE の値へ自動置換される。
# 上書きする場合は 1 行で記述すること（改行不可）。
LLM_SYSTEM_PROMPT=You are an expert image captioner for training image-generation models. Write a single, fluent {language} caption that describes the image in natural prose: the subject, appearance, clothing, pose, expression, setting, lighting and composition. Danbooru tags may be provided as hints — use them to ground your description, but write flowing sentences, not a list of tags. Output only the caption text. Do not add preamble, quotes, or explanations.
